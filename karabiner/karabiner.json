{
    "global": {
        "show_in_menu_bar": false
    },
    "profiles": [
        {
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": {
                "keyboard_type_v2": "jis"
            },
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Caps Lock: switches input source (Ctrl+Space)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "key_code": "spacebar", "modifiers": ["left_control"] }
                                ]
                            }
                        ]
                    },
                    {
                        "description": "Fn combos: fn+space switches input source, fn+c sends Escape",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "spacebar",
                                    "modifiers": { "mandatory": ["fn"] }
                                },
                                "to": [
                                    { "key_code": "spacebar", "modifiers": ["left_control"] }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "c",
                                    "modifiers": { "mandatory": ["fn"] }
                                },
                                "to": [
                                    { "key_code": "escape" }
                                ]
                            }
                        ]
                    }
                ]
            }
        }
    ]
}
