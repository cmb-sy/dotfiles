{
    "global": {
        "show_in_menu_bar": false
    },
    "profiles": [
        {
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": {
                "keyboard_type_v2": "jis"
            },
            "complex_modifications": {
                "rules": [
                    {
                        "description": "F1 → voice-out (直前の Claude 応答を再生/停止トグル)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "f1",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "shell_command": "$HOME/dotfiles/bin/voice-out" }
                                ]
                            }
                        ]
                    },
                    {
                        "description": "Caps Lock -> voice input toggle. Typeless モード時は Virtual HID 経由で F18 を直接 emit (synthetic key 拒否を回避)、Handy モード時は bin/voice-toggle 経由。エンジン切替は voice-switch が karabiner_cli --set-variables で voice_engine を更新する。",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "key_code": "f18" }
                                ],
                                "conditions": [
                                    { "type": "variable_if", "name": "voice_engine", "value": "typeless" }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "shell_command": "$HOME/dotfiles/bin/voice-toggle" }
                                ],
                                "conditions": [
                                    { "type": "variable_unless", "name": "voice_engine", "value": "typeless" }
                                ]
                            }
                        ]
                    },
                    {
                        "description": "Fn combos: fn+space switches input source, fn+c sends Escape, fn+f formats clipboard via Claude (ai-format)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "spacebar",
                                    "modifiers": { "mandatory": ["fn"] }
                                },
                                "to": [
                                    { "key_code": "spacebar", "modifiers": ["left_control"] }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "c",
                                    "modifiers": { "mandatory": ["fn"] }
                                },
                                "to": [
                                    { "key_code": "escape" }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "f",
                                    "modifiers": { "mandatory": ["fn"] }
                                },
                                "to": [
                                    { "shell_command": "$HOME/dotfiles/bin/ai-format" }
                                ]
                            }
                        ]
                    }
                ]
            }
        }
    ]
}
