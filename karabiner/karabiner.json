{
    "global": {
        "show_in_menu_bar": false
    },
    "profiles": [
        {
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": {
                "keyboard_type_v2": "jis"
            },
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Caps Lock -> toggle Handy speech-to-text (bin/handy-toggle): press to start recording, press again to stop + transcribe (ja) + paste. Handy runs always-resident; CLI --toggle-transcription is forwarded to it.",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "shell_command": "/Users/snakashima/dotfiles/bin/handy-toggle" }
                                ]
                            }
                        ]
                    },
                    {
                        "description": "Fn combos: fn+space switches input source, fn+c sends Escape, fn+f formats clipboard via Claude (ai-format)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "spacebar",
                                    "modifiers": { "mandatory": ["fn"] }
                                },
                                "to": [
                                    { "key_code": "spacebar", "modifiers": ["left_control"] }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "c",
                                    "modifiers": { "mandatory": ["fn"] }
                                },
                                "to": [
                                    { "key_code": "escape" }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "f",
                                    "modifiers": { "mandatory": ["fn"] }
                                },
                                "to": [
                                    { "shell_command": "/Users/snakashima/dotfiles/bin/ai-format" }
                                ]
                            }
                        ]
                    }
                ]
            }
        }
    ]
}
