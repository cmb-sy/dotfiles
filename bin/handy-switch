#!/bin/zsh
# Switch Handy's voice post-processing across three locked modes, anytime.
#
#   handy-switch ja            -> ollama qwen3:4b (offline; STT locked to ja, max JP accuracy)
#   handy-switch en            -> ollama qwen3:4b (offline; STT locked to en, max EN accuracy)
#   handy-switch cloud [model] -> Cerebras gpt-oss-120b (STT=auto, bilingual ja/en; text sent to US)
#   handy-switch reapply       -> re-run apply with the current provider+language (use after editing
#                                 prompt template / glossary.txt to push the new content into settings)
#   handy-switch status        -> print current provider / model / language / prompt / cancel key
#   handy-switch local         -> back-compat alias for `ja`
#
# Why three locked modes instead of one auto: local whisper-turbo cannot reliably auto-detect
# language on short or accented utterances (it tends to fall back to ja and phonetically transcribe
# English as katakana). So local is language-locked. Use `cloud` when you actually need bilingual
# auto-detect — its whisper is more capable. The ja_light_tidy prompt + glossary handle both langs.
#
# Handy owns settings_store.json and rewrites it from memory while running, so an
# external edit only sticks if Handy is fully quit first; we quit -> apply -> relaunch.
#
# CLOUD target is Cerebras, chosen because it neither RETAINS nor TRAINS on data:
#   - no retention: https://support.cerebras.net/articles/1811589793-does-cerebras-retain-my-data
#   - no training:  https://www.cerebras.ai/terms-of-service
# US text transmission is acceptable per the user; data-training is the hard no-go.
#
# The Cerebras API key lives ONLY in the macOS login Keychain (never committed).
# Store it once per machine:
#   security add-generic-password -s handy-cerebras-api-key -a "$USER" -w "<KEY>"
set -euo pipefail

KEYCHAIN_SVC="handy-cerebras-api-key"
SETTINGS="$HOME/Library/Application Support/com.pais.handy/settings_store.json"
HERE="${0:A:h}"                 # .../dotfiles/bin
APPLY="${HERE:h}/handy/apply-settings.py"

die() { print -u2 "handy-switch: $*"; exit 1 }

quit_handy() {
  /usr/bin/osascript -e 'quit app "Handy"' >/dev/null 2>&1 || true
  local n=0
  while /usr/bin/pgrep -x handy >/dev/null 2>&1; do
    (( ++n > 50 )) && die "Handy did not quit within 5s"
    sleep 0.1
  done
}

relaunch_handy() {
  # 'open -a Handy' issued right after a quit can fail with -600 (procNotFound) because
  # LaunchServices still holds a stale descriptor for the just-exited process. Re-issue the
  # open on an interval until pgrep sees it, rather than trying once and giving up silently.
  local n=0
  until /usr/bin/pgrep -x handy >/dev/null 2>&1; do
    (( n % 15 == 0 )) && { /usr/bin/open -a Handy >/dev/null 2>&1 || true; }
    (( ++n > 75 )) && { print -u2 "handy-switch: Handy did not relaunch in ~15s; run 'open -a Handy' manually"; break; }
    sleep 0.2
  done
}

print_status() {
  [[ -f "$SETTINGS" ]] || die "settings not found: $SETTINGS"
  /usr/bin/python3 - "$SETTINGS" <<'PY'
import json, sys
s = json.load(open(sys.argv[1])).get("settings", {})
pid = s.get("post_process_provider_id")
print(f"provider = {pid}")
print(f"model    = {s.get('post_process_models', {}).get(pid, '')}")
print(f"language = {s.get('selected_language')}")
print(f"enabled  = {s.get('post_process_enabled')}")
print(f"prompt   = {s.get('post_process_selected_prompt_id')}")
print(f"cancel   = {s.get('bindings', {}).get('cancel', {}).get('current_binding')}")
PY
}

[[ -f "$APPLY" ]] || die "applier not found: $APPLY"

apply_cloud() {
  # $1 = language ("auto" for the cloud subcommand, or carried-over for reapply)
  local lang="$1" model_arg="${2:-}"
  local key
  key="$(/usr/bin/security find-generic-password -s "$KEYCHAIN_SVC" -w 2>/dev/null || true)"
  [[ -n "$key" ]] || die "no Cerebras key in Keychain. Add it once:
  security add-generic-password -s $KEYCHAIN_SVC -a \"\$USER\" -w \"<KEY>\""
  quit_handy
  if [[ -n "$model_arg" ]]; then
    CEREBRAS_API_KEY="$key" /usr/bin/python3 "$APPLY" --provider cloud --language "$lang" --model "$model_arg"
  else
    CEREBRAS_API_KEY="$key" /usr/bin/python3 "$APPLY" --provider cloud --language "$lang"
  fi
  relaunch_handy
}

apply_local() {
  # $1 = language ("ja" or "en")
  local lang="$1"
  quit_handy
  /usr/bin/python3 "$APPLY" --provider local --language "$lang"
  relaunch_handy
}

case "${1:-status}" in
  status)
    print_status
    ;;
  ja|local)  # 'local' kept as back-compat alias for 'ja'
    apply_local ja
    print -r -- "-> JA (ollama qwen3:4b, language=ja). Offline; max Japanese accuracy."
    ;;
  en)
    apply_local en
    print -r -- "-> EN (ollama qwen3:4b, language=en). Offline; max English accuracy."
    ;;
  cloud)
    apply_cloud auto "${2:-}"
    print -r -- "-> CLOUD (Cerebras, language=auto). Bilingual; text sent to US, no retention/training."
    ;;
  reapply)
    # Re-run apply with whatever provider+language is currently set. Used after editing the
    # prompt template or glossary.txt so the regenerated content lands in settings_store.json
    # without forcing the user to remember which mode they were in.
    cur="$(/usr/bin/python3 - "$SETTINGS" <<'PY'
import json, sys
s = json.load(open(sys.argv[1])).get("settings", {})
print(f"{s.get('post_process_provider_id','')} {s.get('selected_language','')}")
PY
)"
    cur_provider="${cur%% *}"
    cur_language="${cur##* }"
    [[ -n "$cur_provider" && -n "$cur_language" ]] || die "could not read current provider/language from settings"
    if [[ "$cur_provider" == "cerebras" ]]; then
      apply_cloud "$cur_language"
    else
      apply_local "$cur_language"
    fi
    print -r -- "-> reapplied provider=$cur_provider language=$cur_language"
    ;;
  *)
    die "usage: handy-switch [ja | en | cloud [model] | reapply | status]"
    ;;
esac
