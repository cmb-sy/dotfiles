#!/bin/bash
# Toggle Handy speech-to-text recording, bound to Caps Lock via Karabiner.
# Handy runs always-resident (autostart_enabled); --toggle-post-process is a CLI
# arg forwarded to the running instance via Tauri single-instance (no key synthesis,
# so no stuck modifier / no character leak -- unlike sending option+shift+space). Press
# to start recording, press again to stop -> whisper(turbo,ja) transcribe -> LLM
# post-process (ollama qwen3:4b-instruct-2507, "JP Light Tidy" prompt: punctuation +
# filler removal + homophone fix, no paraphrase) -> paste. Karabiner runs this in a
# minimal launchd env, so use absolute paths.
BIN="/Applications/Handy.app/Contents/MacOS/handy"

# If Handy isn't running yet, just launch it (this press won't record).
if ! /usr/bin/pgrep -x handy >/dev/null 2>&1; then
  /usr/bin/open -a Handy
  exit 0
fi

exec "$BIN" --toggle-post-process
