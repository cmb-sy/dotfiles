#!/bin/bash
# Display all custom keybindings across tools
# Usage: help_key [wezterm|ghostty|cmux|shell|voice|all]

BOLD='\033[1m'
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
RESET='\033[0m'

section() { echo -e "\n${BOLD}${CYAN}━━━ $1 ━━━${RESET}\n"; }
group()   { echo -e "  ${YELLOW}$1${RESET}"; }
kv()      { printf "    ${GREEN}%-24s${RESET} %s\n" "$1" "$2"; }

show_wezterm() {
  section "WezTerm"

  group "Tabs"
  kv "Cmd+T"              "New tab"
  kv "Cmd+W"              "Close tab"
  kv "Cmd+1-9"            "Switch to tab N"
  kv "Cmd+Shift+[ / ]"    "Previous / Next tab"

  group "Panes"
  kv "Cmd+Shift+\\"       "Split vertical (down)"
  kv "Cmd+Shift+-"        "Split horizontal (right)"
  kv "Cmd+Alt+Arrow"      "Move between panes"
  kv "Ctrl+Shift+Arrow"   "Resize pane"
  kv "Cmd+Shift+Enter"    "Zoom pane (toggle)"

  group "Font"
  kv "Ctrl+Shift+- / ="   "Font size down / up"
  kv "Cmd+0"              "Reset font size"

  group "Tools"
  kv "Alt+Cmd+H"          "Show this keybindings list"
  kv "Cmd+Shift+P"        "Command palette"
  kv "Cmd+F"              "Search scrollback"
  kv "Cmd+Shift+F"        "Directory: fuzzy cd (whole scope)"
  kv "Alt+Cmd+F"          "Directory: fuzzy cd (whole scope)"
  kv "Ctrl+Shift+O"       "Project sessionizer (dev)"
  kv "Ctrl+Shift+X"       "Copy mode"
  kv "Ctrl+Shift+Space"   "Quick select (URLs, paths)"
}

show_ghostty() {
  section "Ghostty"

  group "Quick Terminal"
  kv "Cmd+\`"             "Toggle quick terminal (drops from top)"

  group "Tabs"
  kv "Cmd+T"              "New tab"
  kv "Cmd+Left / Right"   "Previous / Next tab"

  group "Panes"
  kv "Cmd+Shift+-"        "Split right (vertical)"
  kv "Cmd+Shift+\\"       "Split down (horizontal)"
  kv "Cmd+Shift+Arrow"    "Move between splits"

  group "Tools"
  kv "Cmd+F"              "Search scrollback"
  kv "Cmd+Shift+F"        "Fuzzy cd (zsh fzf, whole scope)"
  kv "Cmd+Ctrl+F"         "Toggle fullscreen"
  kv "Shift+Enter"        "Newline (Claude Code, etc.)"
}

show_cmux() {
  section "cmux"

  group "Launch"
  kv "open -a cmux"       "cmux を起動するだけ (Spotlight/Dock と同じ)"
  kv "cmux ."             "カレントを開く (未起動なら起動も兼ねる)"
  kv "cmux <path>"        "指定ディレクトリを新規 workspace で開く"

  group "Config"
  kv "cmux reload-config" "Ghostty + cmux.json を再読込 (再起動不要)"
}

show_claude() {
  section "Claude Code"

  group "Input editing"
  kv "Esc"                "入力を全消去（ドラフトをキャンセル）"
  kv "Ctrl+U"             "カーソルから行頭まで一括削除"
  kv "Ctrl+W"             "単語を後方削除"
  kv "Shift+Enter"        "改行（送信せず）"
  kv "Ctrl+C"             "処理を中断（入力消去ではない）"
}

show_shell() {
  section "Shell Aliases"

  group "Navigation"
  kv ".."                  "cd .."
  kv "..."                 "cd ../.."
  kv "...."                "cd ../../.."

  group "Docker"
  kv "d"                   "docker"
  kv "dc"                  "docker compose"
  kv "dps"                 "docker ps"
  kv "dpsa"                "docker ps -a"
  kv "dimg"                "docker images"

  group "Claude"
  kv "clp"                 "claude（個人）"
  kv "clw"                 "claude（会社）"
  kv "clpa"                "自律（個人）"
  kv "clwa / claude-auto"  "自律（会社）"
  kv "claude-link-shared" "共有設定を両アカウントにリンク"

  group "Dev Tools"
  kv "dev"                  "Project sessionizer (fzf + nvim)"
  kv "help_key / Alt+Cmd+H" "Show this keybindings list"

  group "Fuzzy search (fzf)"
  kv "Cmd+Shift+F / cdg"     "Directory: fuzzy cd (whole scope)"
  kv "Alt+C"                "Directory: fuzzy cd (current tree only)"
  kv "Ctrl+R"               "History: fuzzy search"
  kv "Ctrl+T"               "File: fuzzy insert path"

  group "Others"
  kv "la"                  "ls -a"
  kv "h"                   "history"
  kv "tenki"               "weather"
}

show_voice() {
  section "Voice Input (Karabiner + Handy)"

  group "Recording"
  kv "Caps Lock"          "録音 開始 / 停止 → 文字起こし(ja) → ペースト"
  kv "C"                  "録音をキャンセル（録音中のみ有効）"

  group "Input / Format"
  kv "fn+Space"           "入力ソース切替 (Ctrl+Space)"
  kv "fn+C"               "Escape を送出"
  kv "fn+F"               "クリップボードを Claude で整形 (ai-format)"

  group "Mode switch (STT + post-processing)"
  kv "hsja / handy-switch ja"      "ローカル(ollama) + STT=ja。日本語専用、最高精度、オフライン"
  kv "hsen / handy-switch en"      "ローカル(ollama) + STT=en。英語専用、最高精度、オフライン"
  kv "hscl / handy-switch cloud"   "Cerebras + STT=auto。bilingual、ネット要、品質高"
  kv "hslo / handy-switch local"   "ja の後方互換エイリアス (hsja と等価)"
  kv "handy-switch reapply"        "現在のモードのまま再適用 (glossary 編集後など)"
  kv "handy-switch status"         "現在の provider / model / language を表示"
}

case "${1:-all}" in
  wezterm)  show_wezterm ;;
  ghostty)  show_ghostty ;;
  cmux)     show_cmux ;;
  claude)   show_claude ;;
  shell|sh) show_shell ;;
  voice)    show_voice ;;
  all)
    show_wezterm
    show_ghostty
    show_cmux
    show_claude
    show_shell
    show_voice
    echo ""
    ;;
  *)
    echo "Usage: help_key [wezterm|ghostty|cmux|claude|shell|voice|all]"
    exit 1
    ;;
esac
