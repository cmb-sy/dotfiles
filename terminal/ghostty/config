# Ghostty config

# ---------------------------------------------------------------------------
# Theme
# ---------------------------------------------------------------------------
theme = light:Catppuccin Latte,dark:Catppuccin Frappe

# ---------------------------------------------------------------------------
# Vivid colors
# ---------------------------------------------------------------------------
background = #0B1020
foreground = #F0F6FF
cursor-color = #8FDBFF
cursor-text = #0B1020
selection-foreground = #0B1020
minimum-contrast = 1.2

# ANSI palette
palette = 1=#FF5C8A
palette = 2=#5CFFB4
palette = 3=#FFD45C
palette = 4=#5CC8FF
palette = 5=#C18CFF
palette = 6=#5CFFF2
palette = 9=#FF8FAF
palette = 10=#8FFFD4
palette = 11=#FFE08F
palette = 12=#8FDBFF
palette = 13=#D6B3FF
palette = 14=#8FFFF8

# ---------------------------------------------------------------------------
# Font
# ---------------------------------------------------------------------------
font-family = Monaspace Neon
font-feature = calt
font-feature = liga
font-feature = dlig
font-size = 15
font-thicken = true
font-thicken-strength = 140
adjust-cell-height = 10%

# HackGen
font-family = HackGen
font-codepoint-map = U+3000-U+303F,U+3040-U+309F,U+30A0-U+30FF,U+4E00-U+9FFF,U+FF00-U+FFEF=HackGen
font-codepoint-map = U+3400-U+4DBF,U+20000-U+2A6DF=HackGen

# ---------------------------------------------------------------------------
# Window
# ---------------------------------------------------------------------------
background-opacity = 0.80
background-opacity-cells = true
background-blur = 24
window-padding-y = 2,8
window-padding-x = 8,8
window-padding-balance = true
window-padding-color = extend
# Windowed startup so background-opacity / blur apply (native fullscreen disables opacity on macOS).
fullscreen = false
macos-titlebar-style = tabs
window-theme = dark
window-title-font-family = Monaspace Neon
# When you toggle fullscreen manually: non-native + menu visible (tabs + non-native have caveats in Ghostty docs).
macos-non-native-fullscreen = visible-menu

# ---------------------------------------------------------------------------
# Terminal
# ---------------------------------------------------------------------------
scrollback-limit = 10000
shell-integration = zsh
mouse-shift-capture = true

# ---------------------------------------------------------------------------
# Bell
# ---------------------------------------------------------------------------
bell-features = system,audio,attention

# ---------------------------------------------------------------------------
# Link / Notifications
# ---------------------------------------------------------------------------
link-url = true
notify-on-command-finish = unfocused

# ---------------------------------------------------------------------------
# Keybindings
# ---------------------------------------------------------------------------
config-file = keybindings.conf
