{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,
  "shortcuts": {
    "bindings": {
      "newTab": "cmd+s",
      "prevSidebarTab": "cmd+up",
      "nextSidebarTab": "cmd+down",
      "prevSurface": "cmd+left",
      "nextSurface": "cmd+right",
      "focusLeft": "cmd+shift+left",
      "focusRight": "cmd+shift+right",
      "focusUp": "cmd+shift+up",
      "focusDown": "cmd+shift+down",
      "splitRight": "cmd+shift+-",
      "splitDown": "cmd+shift+\\",
      "findInDirectory": "unbound",
      "saveFilePreview": "unbound"
    }
  }
}
