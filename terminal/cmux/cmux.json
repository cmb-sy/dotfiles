{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,
  "shortcuts": {
    "bindings": {
      "newTab": "cmd+s",
      "prevSidebarTab": "cmd+up",
      "nextSidebarTab": "cmd+down",
      "prevSurface": "cmd+left",
      "nextSurface": "cmd+right",
      "saveFilePreview": "unbound"
    }
  }
}
