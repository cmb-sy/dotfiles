#!/bin/sh
# VS Code writes git.ignoredRepositories into settings.json when you use
# "Hide from Source Control Repositories" on a nested repo/worktree in
# whichever workspace happens to be focused at the time. The value is an
# absolute, machine-local worktree path unrelated to this repo's content —
# committing it leaks a real path (and username) to the pushed remote.
if git diff --cached --name-only | grep -qx '\.vscode/settings\.json'; then
  if git diff --cached -- .vscode/settings.json | grep '^+' | grep -q 'git.ignoredRepositories'; then
    echo "error: .vscode/settings.json stages 'git.ignoredRepositories'." >&2
    echo "This key is auto-generated by VS Code and leaks a machine-local worktree path. Remove it before committing." >&2
    exit 1
  fi
fi
